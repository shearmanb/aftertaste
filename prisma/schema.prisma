generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Producer {
  id        String  @id @default(cuid())
  name      String
  quality   String?
  beanNotes String?
  variance  String?
  website   String?
  beans     Bean[]
}

model Bean {
  id           String   @id @default(cuid())
  producer     Producer @relation(fields: [producerId], references: [id])
  producerId   String
  name         String
  region       String?
  roastLevel   String
  process      String?
  tastingNotes String[]
  imageUrl     String?
  productUrl   String?
  notes        String?
  createdAt    DateTime @default(now())
  brews        Brew[]
}

model WaterProfile {
  id        String  @id @default(cuid())
  brand     String
  additives String?
  notes     String?
  brews     Brew[]
}

model FilterProfile {
  id    String  @id @default(cuid())
  name  String
  notes String?
  brews Brew[]
}

model DropdownOption {
  id       String @id @default(cuid())
  category String
  value    String

  @@unique([category, value])
}

model GrindProfile {
  id      String @id @default(cuid())
  name    String
  grinder String @default("Fellow Ode Gen 2")
  setting Float
  notes   String?
  brews   Brew[]
}

model AidenProfile {
  id          String @id @default(cuid())
  name        String
  coffeeG     Float
  waterG      Float
  tempF       Int
  bloomTimeS  Int
  bloomWaterG Float
  pours       Json
  notes       String?
  brews       Brew[]
}

model Brew {
  id              String         @id @default(cuid())
  brewedAt        DateTime       @default(now())
  roastedOn       DateTime?
  openedOn        DateTime?
  bean            Bean           @relation(fields: [beanId], references: [id])
  beanId          String
  waterProfile    WaterProfile?  @relation(fields: [waterProfileId], references: [id])
  waterProfileId  String?
  filterProfile   FilterProfile? @relation(fields: [filterProfileId], references: [id])
  filterProfileId String?
  grindProfile    GrindProfile   @relation(fields: [grindProfileId], references: [id])
  grindProfileId  String
  aidenProfile    AidenProfile   @relation(fields: [aidenProfileId], references: [id])
  aidenProfileId  String
  actualCoffeeG   Float?
  brewIssues      String[]
  tastingNote     TastingNote?
}

model TastingNote {
  id              String   @id @default(cuid())
  brew            Brew     @relation(fields: [brewId], references: [id], onDelete: Cascade)
  brewId          String   @unique
  overallScore    Float
  fruit           Float
  bitterness      Float
  chocolate       Float
  sourness        Float
  drinkingTempF   Int?
  flavorTags      String[]
  confirmedTags   String[]
  missedTags      String[]
  bonusTags       String[]
  initialThoughts String?
  bestPart        String?
  worstPart       String?
  changesToMake   String?
  wouldBrewAgain  Boolean  @default(true)
  createdAt       DateTime @default(now())
}
